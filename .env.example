# Server
PORT=4000
NODE_ENV=development

# Database (Docker default shown)
DATABASE_URL="postgresql://toolmarket:toolmarket@localhost:55432/toolmarket?schema=public"

# Auth — HS256 access tokens for the API. For NextAuth JWT sessions on the Next.js app, set
# NEXTAUTH_SECRET (or AUTH_SECRET) to the **same value** as JWT_SECRET so tokens can be verified both places.
JWT_SECRET="change-me-use-long-random-string"

# CORS (comma-separated origins)
CORS_ORIGINS="http://localhost:3000"

# Used for Stripe Connect return/refresh URLs
FRONTEND_URL="http://localhost:3000"
STRIPE_CONNECT_COUNTRY="GB"

# Stripe (test mode)
# Secret key: from Dashboard → Developers → API keys, OR `stripe config --list` (test_mode_api_key)
STRIPE_SECRET_KEY="sk_test_..."
# Local webhooks: `stripe listen --forward-to http://localhost:4000/stripe/webhook` then paste the
# "webhook signing secret" from that command, OR run `stripe listen --print-secret` (use value in .env only)
STRIPE_WEBHOOK_SECRET="whsec_..."

# Internal cron / manual payout trigger (optional extra guard)
CRON_SECRET="change-me"

# First admin user email (optional — grants ADMIN role on first register if unset use manual DB)
ADMIN_EMAIL="admin@example.com"
